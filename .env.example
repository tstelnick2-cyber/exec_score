# ─── Database ────────────────────────────────────────────────────────────────
# Required. Postgres connection string from your local DB or Render.
DATABASE_URL=postgres://user:password@localhost:5432/kyronix

# ─── API server (local dev) ──────────────────────────────────────────────────
# Required by artifacts/api-server (throws if unset).
PORT=8080
# Required by artifacts/api-server/src/lib/logger.ts to enable terse JSON logs.
NODE_ENV=development
# Optional: shipped-from address when sending OTP emails.
RESEND_API_KEY=

# ─── Clerk auth (production only — leave empty in dev) ───────────────────────
# Used by the api-server to proxy Clerk Frontend API requests when deployed
# behind a custom domain. Set these ONLY in production / Render env.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ─── Frontend (local dev) ────────────────────────────────────────────────────
# PORT for the Vite dev server (artifacts/kyronix).
PORT=5173
# BASE_PATH under which the SPA is served. Use "/" for root, "/app" for subpath.
BASE_PATH=/
# Where /api requests get proxied in dev (the local api-server).
VITE_API_PROXY_TARGET=http://localhost:8080
# Absolute URL of the api-server used in production builds. Leave empty in dev.
VITE_API_BASE_URL=
# Clerk publishable key for the browser. Empty in dev (Clerk dev instance).
VITE_CLERK_PUBLISHABLE_KEY=
# Clerk Frontend API proxy URL used in production (api-server's /api/__clerk).
VITE_CLERK_PROXY_URL=
